# =============================================================================
# AI TRADING BOT - CONFIGURATION
# =============================================================================
# Save this file as: config.env (in same folder as the bot)

# ===========================================
# 🧠 ANTHROPIC API (Claude AI Brain)
# ===========================================
# Get your key: https://console.anthropic.com/settings/keys
# Pricing: ~$0.003 per analysis cycle (very cheap)
# The bot uses Claude Sonnet for fast + smart decisions
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===========================================
# 💹 DELTA EXCHANGE API
# ===========================================
# Get keys: https://india.delta.exchange -> Settings -> API Keys
# Enable: Trading + Read permissions
# Whitelist your server IP for security
DELTA_API_KEY=your_delta_api_key
DELTA_API_SECRET=your_delta_api_secret

# Mode: "testnet" or "production"
# START WITH TESTNET! Get testnet keys at: https://testnet.delta.exchange
MODE=testnet

# ===========================================
# 📱 TELEGRAM ALERTS (Optional but recommended)
# ===========================================
# Step 1: Message @BotFather on Telegram -> /newbot -> copy token
# Step 2: Message @userinfobot -> copy your chat_id
TELEGRAM_TOKEN=
TELEGRAM_CHAT_ID=

# ===========================================
# ⚙️ BOT SETTINGS (defaults are good to start)
# ===========================================
RISK_PER_TRADE=0.02
DAILY_LOSS_LIMIT=0.05
MAX_LEVERAGE=10
DEFAULT_LEVERAGE=5
MAX_POSITIONS=3
AI_CHECK_INTERVAL=300
